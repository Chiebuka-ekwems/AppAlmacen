<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".retirarProducto">

    <!-- Título de la pantalla -->
    <TextView
        android:id="@+id/tvTituloRetirar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Retirar Producto"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        app:layout_constraintVertical_bias="0.05"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Bloque de búsqueda -->
    <LinearLayout
        android:id="@+id/llBloqueBuscar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvTituloRetirar">

        <EditText
            android:id="@+id/etCodigoRetirar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Código del producto"
            android:inputType="text" />

        <Button
            android:id="@+id/btnBuscarRetirar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Buscar"
            android:onClick="buscarParaRetirar" />
    </LinearLayout>

    <!-- Bloque de información del producto (Cajita gris redondeada) -->
    <LinearLayout
        android:id="@+id/llInfoProducto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/llBloqueBuscar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descripción:"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDescRetirar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="---"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stock Actual:"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStockRetirar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="---"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- Botón final de acción -->
    <Button
        android:id="@+id/btnConfirmarRetirar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:backgroundTint="#D32F2F"
        android:text="Eliminar Producto del Almacén"
        android:textColor="@color/white"
        android:onClick="confirmarRetirar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>